# =============================================================================
# SettleKit environment configuration
# Copy to `.env` and fill in real values. Never commit a real .env file.
# =============================================================================

# --- Core ---------------------------------------------------------------------

# PostgreSQL connection string used by @settlekit/database.
DATABASE_URL=postgresql://settlekit:settlekit@localhost:5432/settlekit

# Listen port for the API (default 8787) and for Next apps started with -p $PORT.
PORT=8787

# --- Arc settlement (USDC chain) ----------------------------------------------
#
# Arc is Circle's stablecoin L1 (USDC is the native gas token). Set ARC_CHAIN_ID
# to enable on-chain settlement. For a KNOWN chain (Arc testnet = 5042002), the
# RPC URL and USDC/EURC/USYC addresses default from the bundled chain config, so
# ARC_CHAIN_ID is the only required var. Override RPC/USDC below for a private
# RPC (Alchemy/QuickNode) or a custom deployment.
#
# Arc testnet: chainId 5042002, RPC https://rpc.testnet.arc.network,
# USDC 0x3600…0000 (native gas), explorer testnet.arcscan.app, faucet faucet.circle.com.

# Numeric chain id for the Arc network (5042002 = Arc testnet).
ARC_CHAIN_ID=5042002

# Optional override of the JSON-RPC endpoint (defaults from the chain config).
# ARC_RPC_URL=https://rpc.testnet.arc.network

# Optional override of the USDC token contract (defaults from the chain config).
# Required only for an unknown ARC_CHAIN_ID.
# ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# --- Circle (Gateway / x402 payment rails) ------------------------------------

# Circle API key for Gateway and x402 paid-API settlement.
CIRCLE_API_KEY=test_circle_api_key_replace_me

# --- Circle developer-controlled wallets (real payout execution) --------------
#
# Used by POST /v1/payouts/:id/execute to move USDC from a SettleKit treasury
# wallet to a merchant. Set both API key + the funding wallet id to enable;
# unset leaves /execute returning a clear "not configured" error (settle via
# /paid instead). Use the W3S sandbox base URL for testnet.
# CIRCLE_WALLETS_API_KEY=TEST_API_KEY:...
# CIRCLE_WALLETS_WALLET_ID=<treasury wallet id>
# CIRCLE_WALLETS_BASE_URL=https://api-sandbox.circle.com
# RSA-encrypted entity secret ciphertext (Circle wants a fresh one per request;
# a static value suits low-volume/dev — prefer a per-call KMS provider in prod).
# CIRCLE_WALLETS_ENTITY_SECRET_CIPHERTEXT=

# CCTP cross-chain pay-in (/v1/cctp) polls Circle's Iris attestation API.
# Defaults to the testnet sandbox; override for mainnet (https://iris-api.circle.com).
# CCTP_IRIS_BASE_URL=https://iris-api-sandbox.circle.com

# --- Circle Gas Station (sponsored gas) + Circle Mint (mint/redeem) -----------
#
# Gas Station: enables POST/GET /v1/gas-station/policies for sponsoring user gas.
# (The /v1/paymaster/* config/permit/encode endpoints are permissionless and
# always available — Circle Paymaster is a permissionless ERC-4337 contract.)
# GAS_STATION_API_KEY=
# GAS_STATION_BASE_URL=https://api.circle.com
# GAS_STATION_POLICIES_PATH=/v1/w3s/gasStation/policies
#
# Circle Mint: enables /v1/mint + /v1/mint/redeem (treasury top-up / off-ramp).
# CIRCLE_MINT_API_KEY=
# CIRCLE_MINT_BASE_URL=https://api.circle.com

# --- Circle Compliance Engine (transaction screening) -------------------------
#
# When set, payout destination addresses are screened for sanctions/risk before
# funds move (POST /v1/payouts/:id/execute); a DENIED/sanctioned address is
# blocked with HTTP 403 compliance_blocked. Unset = pass-through (logged).
# COMPLIANCE_API_KEY=
# COMPLIANCE_BASE_URL=https://api.circle.com
# Circle chain to screen against for networks Circle does not list (e.g. Arc).
# Sanctions hits are address-scoped, so screening on a supported chain still
# catches them. Defaults to ETH.
# COMPLIANCE_DEFAULT_CHAIN=ETH

# --- Circle inbound webhooks (real-time payout settlement) --------------------
#
# POST /v1/circle/webhooks is a PUBLIC receiver authenticated by Circle's ECDSA
# signature (verified against the public key fetched with the wallets API key).
# It settles payouts in real time on transactions.* events (the worker
# payout-reconcile poll remains as a fallback). Requires CIRCLE_WALLETS_API_KEY
# (above) to fetch Circle's signature public keys; unset = receiver returns
# "not configured".

# --- GitHub (private repo + team access delivery) -----------------------------

# Numeric GitHub App id.
GITHUB_APP_ID=123456

# GitHub App private key (PEM). Use literal \n escapes or a single-line PEM.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END RSA PRIVATE KEY-----"

# Secret used to verify inbound GitHub webhook signatures.
GITHUB_WEBHOOK_SECRET=replace_with_github_webhook_secret

# --- Discord (community / role access delivery) -------------------------------

# Bot token used to add/remove Discord roles on purchase.
DISCORD_BOT_TOKEN=replace_with_discord_bot_token

# --- Email (transactional, via Resend) ----------------------------------------

# Resend API key for sending delivery/receipt emails.
RESEND_API_KEY=re_replace_with_resend_api_key

# From address for outbound transactional email.
EMAIL_FROM=SettleKit <no-reply@settlekit.example>

# --- File storage (S3 / Cloudflare R2 for digital downloads) ------------------

# S3/R2 region. For R2 use "auto".
S3_REGION=auto

# S3/R2 endpoint URL (omit for native AWS S3; required for R2).
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Bucket holding sellable file assets.
S3_BUCKET=settlekit-files

# S3/R2 access credentials.
S3_ACCESS_KEY_ID=replace_with_access_key_id
S3_SECRET_ACCESS_KEY=replace_with_secret_access_key

# --- Webhooks -----------------------------------------------------------------

# Secret used to sign outbound webhook payloads (HMAC) so receivers can verify.
WEBHOOK_SIGNING_SECRET=replace_with_webhook_signing_secret

# --- Next.js apps -------------------------------------------------------------

# Public base URL of the SettleKit API, read by the browser-facing Next apps.
NEXT_PUBLIC_API_URL=http://localhost:8787

# =============================================================================
# Everything below is OPTIONAL for local dev — the API boots with none of it
# (in-memory clients + in-memory persistence). See docs/CONFIGURATION.md for the
# authoritative per-component reference, defaults, and value ranges.
# =============================================================================

# --- API: signing secrets (override in production!) ---------------------------

# HMAC secret used to sign license-key tokens. Must match the worker.
# Dev default: settlekit-dev-license-secret
LICENSE_TOKEN_SECRET=settlekit-dev-license-secret

# HMAC secret used to sign the sk_session auth cookie.
# Dev default: settlekit-dev-auth-cookie-secret
AUTH_COOKIE_SECRET=settlekit-dev-auth-cookie-secret

# HMAC secret used to sign proof-of-citation tokens (creator-dashboard +
# citation-toll sidecar). MUST be set in production — if unset, the dashboard
# falls back to a per-process random secret so a known constant is never shipped,
# but proofs then won't verify across instances. Dev default: dev-citation-proof-secret
CITATION_PROOF_SECRET=dev-citation-proof-secret

# --- API: runtime / identity --------------------------------------------------

# Static bootstrap Bearer key so the first authenticated call can mint real API
# keys. Leave unset once real keys exist. (read in middleware/auth.ts)
# API_BOOTSTRAP_KEY=dev_bootstrap_key

# When "production", the sk_session cookie is set Secure. (read in routes/auth.ts)
# NODE_ENV=production

# Merchant identity surfaced on invoices/receipts. (read in context.ts)
MERCHANT_NAME=SettleKit Merchant
# MERCHANT_EMAIL=billing@your-store.example
# MERCHANT_WEBSITE=https://your-store.example

# --- Arc settlement: tuning ---------------------------------------------------

# Confirmations required before a payment is treated as settled (1-1000).
ARC_MIN_CONFIRMATIONS=3

# --- Circle: optional override ------------------------------------------------

# Override the Circle API base URL (e.g. sandbox). Only used when CIRCLE_API_KEY set.
# CIRCLE_BASE_URL=https://api-sandbox.circle.com

# --- GitHub: installation -----------------------------------------------------

# Default installation id the API/worker authenticate as (required with the
# GITHUB_APP_* group above).
GITHUB_INSTALLATION_ID=12345678

# --- File delivery: API process (FILE_DOWNLOAD_*) -----------------------------

# Base URL embedded in signed file-download links.
FILE_DOWNLOAD_BASE_URL=http://localhost:8787/v1/files/download
# HMAC secret used to sign file-download URLs. Override in production.
FILE_DOWNLOAD_SECRET=settlekit-dev-file-secret
# Default signed-link lifetime in seconds (60-2592000).
FILE_DOWNLOAD_EXPIRES_SEC=3600
# Default max downloads per signed link (1-10000).
FILE_DOWNLOAD_MAX_DOWNLOADS=3

# --- x402 paid API (in-process /v1/paid/*) ------------------------------------

# Destination USDC address advertised in the /v1/paid/research x402 challenge.
# Set to your real wallet to actually receive payment. (read in routes/x402.ts)
X402_PAY_TO=0x0000000000000000000000000000000000000000

# =============================================================================
# Worker (apps/worker) — background jobs. Required integrations fail boot if
# missing. File-delivery uses FILE_DELIVERY_* (note: different prefix from API).
# =============================================================================

# --- Worker: file delivery (FILE_DELIVERY_*) ----------------------------------

FILE_DELIVERY_BASE_URL=http://localhost:8787/v1/files/download
FILE_DELIVERY_SECRET=settlekit-dev-file-secret
FILE_DELIVERY_EXPIRES_SEC=3600
FILE_DELIVERY_MAX_DOWNLOADS=5

# --- Worker: subscription / dunning tuning ------------------------------------

# Grace window (days) applied when a renewal is missed (1-365).
SUBSCRIPTION_GRACE_DAYS=3
# Send a renewal reminder when currentPeriodEnd is within this many days (1-365).
SUBSCRIPTION_RENEWAL_REMINDER_DAYS=7

# --- Worker: job intervals (milliseconds) -------------------------------------

WORKER_DELIVERY_INTERVAL_MS=5000
WORKER_PAYMENT_INTERVAL_MS=10000
WORKER_ACCESS_SYNC_INTERVAL_MS=300000
WORKER_RENEWAL_INTERVAL_MS=600000
WORKER_WEBHOOK_RETRY_INTERVAL_MS=30000
WORKER_RECEIPT_EMAIL_INTERVAL_MS=60000
WORKER_RENEWAL_REMINDER_INTERVAL_MS=3600000
WORKER_DUNNING_EMAIL_INTERVAL_MS=3600000
WORKER_ACCESS_EMAIL_INTERVAL_MS=60000
# How often the worker reconciles executed-but-unsettled payouts against Circle.
# Requires the worker to also have CIRCLE_WALLETS_* set (shared with the API);
# unset Circle wallets makes the job a no-op.
WORKER_PAYOUT_RECONCILE_INTERVAL_MS=60000
# Port for the worker's liveness/readiness/metrics HTTP server
# (GET /health, /ready, /metrics).
WORKER_HEALTH_PORT=8788

# =============================================================================
# Services — standalone Rust/Go binaries. Each loads its own env at startup.
# =============================================================================

# --- x402-gateway (Go, default :8402) -----------------------------------------

# TCP address the gateway binds to.
LISTEN_ADDR=:8402
# Origin paid requests are reverse-proxied to (required, valid URL).
UPSTREAM_URL=http://localhost:9000
# Decimal major-unit price per call, e.g. 0.005 (required).
PRICE=0.005
# Settlement asset — only USDC is supported.
CURRENCY=USDC
# Chain to settle on: arc | base | ethereum (required).
NETWORK=arc
# Destination address payments must be sent to (required).
PAY_TO=0x0000000000000000000000000000000000000000
# Product id attributing the gated call for usage accounting (required).
PRODUCT_ID=prod_replace_me
# Canonical identifier of the protected resource (required).
RESOURCE=https://api.example.com/premium
# Optional remote verifier; must respond {"ok":true}.
# VERIFY_URL=https://verify.example.com/x402
# Optional stable nonce. If empty, an HMAC-derived nonce is used instead.
# NONCE=
# Secret that signs derived nonces. Either NONCE or X402_HMAC_SECRET must be set.
X402_HMAC_SECRET=replace_with_x402_hmac_secret

# --- arc-indexer (Rust) -------------------------------------------------------
# Reuses ARC_RPC_URL / ARC_USDC_ADDRESS and SETTLEKIT_API_URL / SETTLEKIT_API_KEY below.

# Payout address to watch as the `to` of relevant USDC Transfer events (required).
WATCH_ADDRESS=0x0000000000000000000000000000000000000000
# Seconds between RPC polls (>0).
POLL_INTERVAL_SECS=12
# Confirmations required before a transfer is posted to the API.
CONFIRMATIONS=3
# Optional starting block; unset starts at the chain head.
# START_BLOCK=0

# --- license-gateway (Rust, default :8090) ------------------------------------
# SETTLEKIT_API_KEY (below) is required; SETTLEKIT_API_URL defaults to localhost:8787.

# TCP port the license gateway binds to.
LICENSE_GATEWAY_PORT=8090
# How long a cached verification result remains valid (seconds).
CACHE_TTL_SECS=30
# Timeout applied to each upstream HTTP request (seconds, >0).
REQUEST_TIMEOUT_SECS=10

# --- webhook-relay (Rust, default :8091) --------------------------------------

# TCP port the webhook relay binds to.
WEBHOOK_RELAY_PORT=8091
# HMAC-SHA256 secret applied to every outbound delivery body (>= 8 chars, required).
SIGNING_SECRET=replace_with_webhook_relay_signing_secret
# Max delivery attempts per subscriber before giving up (>0).
MAX_RETRIES=5
# Base delay (ms) for the exponential backoff schedule (>0).
RETRY_BASE_MS=500

# =============================================================================
# SDKs / CLIs — Node, Python, Go (agentpay). Constructor args override these.
# =============================================================================

# Base URL of the SettleKit HTTP API (default http://localhost:8787).
SETTLEKIT_API_URL=http://localhost:8787
# Bearer token sent as Authorization: Bearer <key>. Required for authed calls.
SETTLEKIT_API_KEY=sk_replace_with_api_key

# Python SDK x402 example helpers (sdks/python/examples only):
# SETTLEKIT_PAY_TO=0xYourMerchantWalletAddress
# SETTLEKIT_NETWORK=base
# SETTLEKIT_VERIFY_MODE=accept
