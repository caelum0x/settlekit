# SettleKit API origin. The @settlekit/react SDK appends `/v1` itself, so do NOT
# include a path here.
NEXT_PUBLIC_SETTLEKIT_API_URL=http://localhost:8787

# Publishable / Bearer API key the SDK sends. For local dev, start the SettleKit
# API with `API_BOOTSTRAP_KEY=sk_dev` and keep this value in sync.
NEXT_PUBLIC_SETTLEKIT_PUBLISHABLE_KEY=sk_dev

# Identifiers for the "Pro" plan the upgrade/checkout flow targets. Override to
# match the merchant/organization/price you created in your SettleKit catalog.
NEXT_PUBLIC_SETTLEKIT_ORG_ID=org_demo
NEXT_PUBLIC_SETTLEKIT_MERCHANT_ID=merchant_demo
NEXT_PUBLIC_SETTLEKIT_PRO_PRICE_ID=price_pro_monthly
NEXT_PUBLIC_SETTLEKIT_PAY_TO_ADDRESS=0x000000000000000000000000000000000000dEaD
