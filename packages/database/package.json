{
  "name": "@settlekit/database",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "drizzle"],
  "bin": {
    "settlekit-migrate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate:run": "node dist/cli.js"
  },
  "dependencies": {
    "@settlekit/common": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.30.6",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
