.env
.env.*
!.env.example

# VCS + tooling
.git
.gitignore
.github
.workflows

# Editor / OS noise
.vscode
.idea
.DS_Store

# Docs / meta not needed at build time
README.md
ARCHITECTURE.md
CONTRIBUTING.md
plan.md

# Test artifacts / coverage
coverage
