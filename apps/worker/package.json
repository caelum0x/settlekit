{
  "name": "@settlekit/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SettleKit background worker — delivery execution, payment confirmation, access sync, renewal sweeps, and webhook retries (plan §17).",
  "main": "./dist/index.js",
  "bin": {
    "settlekit-worker": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node ./dist/index.js",
    "dev": "node --enable-source-maps ./dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@settlekit/api-keys": "workspace:*",
    "@settlekit/arc": "workspace:*",
    "@settlekit/circle-wallets": "workspace:*",
    "@settlekit/citation-toll": "workspace:*",
    "@settlekit/common": "workspace:*",
    "@settlekit/database": "workspace:*",
    "@settlekit/delivery": "workspace:*",
    "@settlekit/discord": "workspace:*",
    "@settlekit/entitlements": "workspace:*",
    "@settlekit/file-delivery": "workspace:*",
    "@settlekit/github": "workspace:*",
    "@settlekit/license-keys": "workspace:*",
    "@settlekit/notifications": "workspace:*",
    "@settlekit/payments": "workspace:*",
    "@settlekit/payouts": "workspace:*",
    "@settlekit/persistence": "workspace:*",
    "@settlekit/saas": "workspace:*",
    "@settlekit/settlement-core": "workspace:*",
    "@settlekit/streaming": "workspace:*",
    "@settlekit/webhooks": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
